{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pakde-tauri",
  "version": "0.3.0",
  "identifier": "com.okihita.pakde-tauri",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "pakde-tauri",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI5NjExRTVENDVGQUUwOApSV1FJcmwvVTVSR1dBaWNweVIzVTlGM1JFWWE0aDlpalJnWUxKVzk5UFBEZkUzbGZUWC9UbnRjSgo=",
      "endpoints": [
        "https://github.com/okihita/PAKDE-tauri/releases/latest/download/latest.json"
      ]
    }
  }
}
